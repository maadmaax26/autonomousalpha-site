# Email Configuration for Webhook Server
# Copy this file to .env and fill in your credentials (never commit .env)

# SMTP Settings (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com

# Gmail: Use app password (NOT your regular password)
# Get it at: https://myaccount.google.com/apppasswords
SMTP_PASS=your_app_password_here

FROM_EMAIL=noreply@autonomousalpha.io

# Stripe Webhook Secret (from Stripe Dashboard)
# Get it at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Server Settings
WEBHOOK_PORT=5000